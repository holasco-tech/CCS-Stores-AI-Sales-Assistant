      "parameters": {
        "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n\n  <style>\n    body {\n      margin: 0;\n      padding: 30px;\n      background: #f4f6f8;\n      font-family: Arial, Helvetica, sans-serif;\n      color: #222222;\n    }\n\n    .quotation {\n      max-width: 750px;\n      margin: 0 auto;\n      background: #ffffff;\n      border: 1px solid #dddddd;\n      border-radius: 10px;\n      overflow: hidden;\n    }\n\n    .header {\n      background: #17365d;\n      color: #ffffff;\n      padding: 28px 35px;\n    }\n\n    .company-name {\n      margin: 0;\n      font-size: 30px;\n      font-weight: 700;\n      letter-spacing: 1px;\n    }\n\n    .document-title {\n      margin: 8px 0 0;\n      font-size: 17px;\n      font-weight: 400;\n    }\n\n    .reference {\n      background: #eef3f8;\n      padding: 16px 35px;\n      border-bottom: 1px solid #dddddd;\n      font-size: 14px;\n      line-height: 1.7;\n    }\n\n    .content {\n      padding: 32px 35px;\n      font-size: 16px;\n      line-height: 1.8;\n    }\n\n    .quotation-output {\n      padding: 22px;\n      background: #f8fafc;\n      border-left: 5px solid #17365d;\n      border-radius: 5px;\n    }\n\n    .footer {\n      padding: 20px 35px;\n      background: #17365d;\n      color: #ffffff;\n      font-size: 13px;\n      line-height: 1.6;\n      text-align: center;\n    }\n\n    .note {\n      margin-top: 25px;\n      padding-top: 18px;\n      border-top: 1px solid #dddddd;\n      color: #555555;\n      font-size: 14px;\n    }\n  </style>\n</head>\n\n<body>\n  <div class=\"quotation\">\n\n    <div class=\"header\">\n      <h1 class=\"company-name\">CCS STORES</h1>\n      <p class=\"document-title\">OFFICIAL SALES QUOTATION</p>\n    </div>\n\n    <div class=\"reference\">\n      <strong>Quotation Number:</strong>\n      CCS-{{ $now.toFormat('yyyyLLdd-HHmmss') }}\n      <br>\n\n      <strong>Date:</strong>\n      {{ $now.toFormat('dd LLLL yyyy') }}\n      <br>\n\n      <strong>Validity:</strong>\n      7 Days\n    </div>\n\n    <div class=\"content\">\n      <div class=\"quotation-output\">\n        {{ $json.output.replace(/\\n/g, '<br>') }}\n      </div>\n\n      <div class=\"note\">\n        Delivery charges will be confirmed after the final delivery address\n        and transportation requirements have been reviewed.\n      </div>\n    </div>\n\n    <div class=\"footer\">\n      Thank you for choosing CCS Stores.<br>\n      Palm Kernel Oil and Palm Kernel Cake Supplier\n    </div>\n\n  </div>\n</body>\n</html>"
